AUTH_MODE=development
STORAGE_MODE=memory
SESSION_SECRET=replace-with-a-long-random-string
ALLOWED_ORIGINS=http://127.0.0.1:8788,http://localhost:3000

# Shared persistence
GITHUB_STORAGE_TOKEN=ghp_replace_me
GIST_ID=replace-with-gist-id
GIST_FILENAME=coins.json

# OAuth
GITHUB_OAUTH_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret
GITHUB_OAUTH_CALLBACK_URL=https://replace-with-worker-host/api/auth/callback

# Optional allowlists
ALLOWED_GITHUB_USERS=
ALLOWED_GITHUB_ORGS=
ALLOWED_GITHUB_EMAILS=

# Password protection for withdraw
WITHDRAW_PASSWORD_HASH=

# Optional explicit API base URL when you put the Worker behind a different route
PUBLIC_API_BASE_URL=