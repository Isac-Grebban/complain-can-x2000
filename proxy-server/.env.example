PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Storage
STORAGE_MODE=gist
GITHUB_STORAGE_TOKEN=ghp_replace_me
GIST_ID=replace-with-gist-id
GIST_FILENAME=coins.json

# Authentication
AUTH_MODE=github
GITHUB_OAUTH_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Optional access restrictions. Leave blank to allow any authenticated GitHub user.
ALLOWED_GITHUB_USERS=
ALLOWED_GITHUB_ORGS=
ALLOWED_GITHUB_EMAILS=

# SHA-256 hex hash of the withdrawal password.
WITHDRAW_PASSWORD_HASH=257db658748423fd296b35652144228b42f6ed345c4996896c2c32f0165db49e

# Local development defaults
DEV_AUTH_USER=Local Dev
DEV_AUTH_LOGIN=local-dev